# Thai Tech Zone Backend Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Docker PostgreSQL)
DB_USER=thaitechzone
DB_PASSWORD=thaitechzone2024
DB_HOST=localhost
DB_PORT=5432
DB_NAME=thaitechzone_db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
JWT_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Email Configuration (for contact form)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ADMIN_EMAIL=admin@thaitechzone.com

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# Omise Payment Configuration (Thai Payment Gateway)
OMISE_SECRET_KEY=skey_test_xxxxx
OMISE_PUBLIC_KEY=pkey_test_xxxxx

# Frontend URL
FRONTEND_URL=http://localhost:3000
REDIRECT_URL=http://localhost:3000/payment-success

# Logging
LOG_LEVEL=debug

# API Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
